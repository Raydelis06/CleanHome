@page "/email-pendiente"
@layout AuthLayout
@using CleanHome.Components.Layout

<div class="container mt-5 text-center">
    <div class="card shadow p-4 mx-auto" style="max-width: 480px;">
        <span class="bi bi-envelope-check fs-1 text-primary"></span>
        <h3 class="mt-3">Revisa tu correo</h3>
        <p class="text-muted">
            Te enviamos un enlace de confirmación.
            Debes confirmar tu email antes de iniciar sesión.
        </p>
        <a href="/Login" class="btn btn-outline-secondary mt-2">
            <span class="bi bi-arrow-left me-1"></span>Volver al Login
        </a>
    </div>
</div>