@using CleanHome.Extensions
@using CleanHome.Models
@using CleanHome.Services
@inject ClienteService clienteService
@inject NavigationManager navegar
@inject ToastService toastService
@page "/Clientes/Editar_Cliente/{Id:int}"
@rendermode InteractiveServer

<PageTitle>Editar Cliente</PageTitle>
<EditForm Model="cliente" OnValidSubmit="Guardar">
	<DataAnnotationsValidator />
	<div class="container">
		<div class="card shadow-lg">
			<div class="card-header text-center">
				<h5 class="card-title">Editar Cliente</h5>
			</div>
			<div class="card-body ">
				<div class="row gx-2 g-5 mt-1 mb-1 justify-content-center">
					@* Nombre *@
					<div class="col-md-5">
						<label class="form-label"><strong>Nombre: </strong>@cliente.Nombre</label>
					</div>
					@* Cédula *@
					<div class="col-md-5">
						<label class="form-label"><strong>Cédula: </strong>@cliente.Cedula</label>
					</div>
					@* Dirección *@
					<div class="col-md-5">
						<label class="form-label"><strong>Dirección</strong></label>
						<InputText class="form-control" @bind-Value="cliente.Direccion"></InputText>
						<ValidationMessage For="@(() => cliente.Direccion)" />
					</div>
					@* Teléfono *@
					<div class="col-md-5">
						<label class="form-label"><strong>Teléfono</strong></label>
						<InputText class="form-control" @bind-Value="cliente.Telefono"></InputText>
						<ValidationMessage For="@(() => cliente.Telefono)" />
					</div>
				</div>
			</div>
			@*footer*@
			<div class="card-footer text-center mt-3 d-flex justify-content-center">
				<div class="d-flex justify-content-between gap-2">
					<a href="/Clientes" class="btn btn-secondary"> <span class="bi bi-arrow-left"></span> Volver</a>
					<button type="submit" class="btn btn-primary bi bi-floppy"> Guardar</button>
					@if (cliente.Estado == Estados.Activo)
					{
						<button class="btn btn-danger bi bi-trash" @onclick="Eliminar"> Eliminar</button>
					}
					else
					{
						<button class="btn btn-success bi bi-arrow-counterclockwise" @onclick="Recuperar"> Recuperar</button>
					}
				</div>
				
			</div>
		</div>
	</div>
</EditForm>

@code
{
	[Parameter]
	public int Id { get; set; }

	Clientes? cliente = new();

	protected override async Task OnInitializedAsync()
	{
		cliente = await clienteService.Buscar(Id);
	}

	async Task Guardar()
	{
		if(cliente != null)
		{
			var modificado = await clienteService.Guardar(cliente);
			if (modificado)
			{
				toastService.ShowSuccess("El cliente ha sido modificado con exito");
				navegar.NavigateTo("/Clientes");
			}
			else
				toastService.ShowWarning("Error al modificar el cliente.");
		}

	}
	async Task Eliminar()
	{
		if(cliente != null)
		{
			var eliminado = await clienteService.Eliminar(cliente);
			if (eliminado)
			{
				toastService.ShowSuccess("El cliente se ha eliminado con exito!");
				navegar.NavigateTo("/Clientes");
			}
			else
				toastService.ShowError("Ha ocurrido un error al eliminar el cliente");
		}

	}
	async Task Recuperar()
	{
		if(cliente != null)
		{
			var recuperado = await clienteService.Recuperar(cliente);
			if (recuperado)
			{
				toastService.ShowSuccess("El cliente ha sido recuperado con exito!");
				navegar.NavigateTo("/Clientes");
			}
			else
				toastService.ShowError("Ha ocurrido un error al recuperar el cliente");
			
		}
		
	}
}
