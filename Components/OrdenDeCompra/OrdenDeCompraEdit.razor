@page "/OrdenesCompra/Editar/{OrdenCompraId:int}"
@rendermode InteractiveServer

@using CleanHome.Extensions
@using CleanHome.Models
@using CleanHome.Services

@inject OrdenCompraService ordenService
@inject ProveedorService proveedorService
@inject MaterialService materialService
@inject NavigationManager navegar
@inject ToastService toastService
@attribute [Authorize(Roles = "Admin")]


<PageTitle>Editar Orden de Compra</PageTitle>

<div class="container">
    <div class="card shadow-lg">

        <!-- HEADER -->
        <div class="card-header text-center">
            <h5 class="card-title">Editar Orden de Compra #@OrdenCompraId</h5>
        </div>

        <EditForm Model="orden" OnValidSubmit="Guardar">
            <DataAnnotationsValidator />

            <div class="card-body">

                <!-- INFORMACIÓN GENERAL -->
                <div class="row gx-2 g-3 mb-4 justify-content-center">

                    <!-- Proveedor -->
                    <div class="col-md-5">
                        <label class="form-label"><strong>Proveedor</strong></label>
                        <InputSelect class="form-control" @bind-Value="orden.ProveedorId"
                                     disabled="@(orden.EstadoOrden != "Pendiente")">
                            <option value="0" disabled>Seleccione un proveedor</option>
                            @foreach (var proveedor in ListaProveedores)
                            {
                                <option value="@proveedor.ProveedorId">@proveedor.Nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => orden.ProveedorId)" />
                    </div>

                    <!-- Fecha -->
                    <div class="col-md-5">
                        <label class="form-label"><strong>Fecha</strong></label>
                        <InputDate class="form-control" @bind-Value="orden.Fecha"
                                   disabled="@(orden.EstadoOrden != "Pendiente")" />
                        <ValidationMessage For="@(() => orden.Fecha)" />
                    </div>

                    <!-- Estado de la Orden -->
                    <div class="col-md-5">
                        <label class="form-label"><strong>Estado de la Orden</strong></label>
                        <input class="form-control" value="@orden.EstadoOrden" disabled />
                    </div>

                    <!-- Total -->
                    <div class="col-md-5">
                        <label class="form-label"><strong>Total</strong></label>
                        <input class="form-control" value="@CalcularTotal().ToString("C2")" disabled />
                    </div>
                </div>

                <hr />

                <!-- SECCIÓN AGREGAR DETALLE (Solo si está Pendiente) -->
                @if (orden.EstadoOrden == "Pendiente")
                {
                    <h6 class="mb-3"><i class="bi bi-plus-circle"></i> Agregar Material</h6>

                    <div class="row g-3 mb-3 align-items-end">

                        <!-- Material (select nativo con onchange) -->
                        <div class="col-md-4">
                            <label class="form-label">Material</label>
                            <select class="form-control" value="@materialSeleccionadoId"
                                    @onchange="OnMaterialSeleccionado">
                                <option value="0" disabled selected>Seleccione</option>
                                @foreach (var material in ListaMateriales)
                                {
                                    <option value="@material.MaterialId">
                                        @material.Nombre - Stock: @material.CantidadDisponible
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- Cantidad (input nativo) -->
                        <div class="col-md-2">
                            <label class="form-label">Cantidad</label>
                            <input type="number" class="form-control" @bind="cantidadTemp" min="1" />
                        </div>

                        <!-- Precio (input nativo) -->
                        <div class="col-md-3">
                            <label class="form-label">Precio Unitario</label>
                            <input type="number" class="form-control" @bind="precioTemp"
                                   min="0.01" step="0.01" />
                            @if (materialSeleccionado != null)
                            {
                                <small class="text-muted">
                                    Precio sugerido: @materialSeleccionado.Precio.ToString("C2")
                                </small>
                            }
                        </div>

                        <!-- Botón Agregar -->
                        <div class="col-md-3">
                            <button type="button" class="btn btn-success w-100" @onclick="AgregarDetalle">
                                <i class="bi bi-plus"></i> Agregar
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(mensajeError))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @mensajeError
                            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
                        </div>
                    }
                }

                <!-- TABLA DE DETALLES -->
                <h6 class="mb-3"><i class="bi bi-list-ul"></i> Detalles de la Orden</h6>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Material</th>
                                <th class="text-center">Cantidad</th>
                                <th class="text-end">Precio Unit.</th>
                                <th class="text-end">Importe</th>
                                @if (orden.EstadoOrden == "Pendiente")
                                {
                                    <th class="text-center">Acción</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @if (orden.Detalles.Any())
                            {
                                @foreach (var (detalle, index) in orden.Detalles.Select((d, i) => (d, i)))
                                {
                                    <tr>
                                        <td>@(index + 1)</td>
                                        <td>@ObtenerNombreMaterial(detalle.MaterialId)</td>
                                        <td class="text-center">@detalle.Cantidad</td>
                                        <td class="text-end">@detalle.Precio.ToString("C2")</td>
                                        <td class="text-end">@((detalle.Cantidad * detalle.Precio).ToString("C2"))</td>
                                        @if (orden.EstadoOrden == "Pendiente")
                                        {
                                            <td class="text-center">
                                                <button type="button" class="btn btn-outline-danger btn-sm"
                                                        @onclick="() => EliminarDetalle(index)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="@(orden.EstadoOrden == "Pendiente" ? 6 : 5)"
                                        class="text-center text-muted">
                                        No hay materiales agregados
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-primary">
                                <td colspan="4" class="text-end"><strong>TOTAL:</strong></td>
                                <td colspan="@(orden.EstadoOrden == "Pendiente" ? 2 : 1)" class="text-end">
                                    <strong>@CalcularTotal().ToString("C2")</strong>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="card-footer text-center mt-3 d-flex justify-content-center">
                <div class="d-flex justify-content-between gap-2">

                    <!-- Botón Volver -->
                    <a href="/OrdenesCompra" class="btn btn-secondary">
                        <span class="bi bi-arrow-left"></span> Volver
                    </a>

                    @if (orden.EstadoOrden == "Pendiente")
                    {
                        <!-- Botón Guardar -->
                        <button type="submit" class="btn btn-primary" disabled="@(!orden.Detalles.Any())">
                            <i class="bi bi-floppy"></i> Guardar
                        </button>

                        <!-- Botón Confirmar -->
                        <button type="button" class="btn btn-success" @onclick="Confirmar"
                                disabled="@(!orden.Detalles.Any())">
                            <i class="bi bi-check-circle"></i> Confirmar
                        </button>

                        <!-- Botón Cancelar Orden -->
                        <button type="button" class="btn btn-danger" @onclick="CancelarOrden">
                            <i class="bi bi-x-circle"></i> Cancelar Orden
                        </button>
                    }

                    @if (orden.EstadoOrden == "Cancelada")
                    {
                        <!-- Botón Recuperar -->
                        <button type="button" class="btn btn-success" @onclick="Recuperar">
                            <i class="bi bi-arrow-counterclockwise"></i> Recuperar
                        </button>

                        <!-- Botón Eliminar Permanente -->
                        <button type="button" class="btn btn-danger" @onclick="EliminarOrden">
                            <i class="bi bi-trash"></i> Eliminar
                        </button>
                    }

                    @if (orden.EstadoOrden == "Confirmada")
                    {
                        <span class="badge bg-success fs-6 d-flex align-items-center">
                            <i class="bi bi-check2-circle me-1"></i> Orden Confirmada
                        </span>
                    }
                </div>
            </div>

        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public int OrdenCompraId { get; set; }

    private OrdenCompra orden = new();
    private List<Proveedores> ListaProveedores = new();
    private List<Materiales> ListaMateriales = new();
    private string mensajeError = string.Empty;

    // Variables temporales SIN DataAnnotations
    private int materialSeleccionadoId = 0;
    private Materiales? materialSeleccionado = null;
    private int cantidadTemp = 1;
    private decimal precioTemp = 0;

    protected override async Task OnInitializedAsync()
    {
        // Cargar la orden
        var ordenBuscada = await ordenService.Buscar(OrdenCompraId);

        if (ordenBuscada != null)
        {
            orden = ordenBuscada;
        }
        else
        {
            toastService.ShowError("Orden no encontrada");
            navegar.NavigateTo("/OrdenesCompra");
            return;
        }

        // Cargar listas
        ListaProveedores = await proveedorService.Listar(p => p.Estado == Estados.Activo);
        ListaMateriales = await materialService.Listar(m => m.Estado == Estados.Activo);
    }

    private void OnMaterialSeleccionado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            materialSeleccionadoId = id;
            materialSeleccionado = ListaMateriales.FirstOrDefault(m => m.MaterialId == id);

            if (materialSeleccionado != null)
            {
                precioTemp = (decimal)materialSeleccionado.Precio;
            }
        }
    }

    private void AgregarDetalle()
    {
        mensajeError = string.Empty;

        // Validaciones manuales
        if (materialSeleccionadoId <= 0)
        {
            mensajeError = "Debe seleccionar un material";
            return;
        }

        if (cantidadTemp <= 0)
        {
            mensajeError = "La cantidad debe ser mayor a 0";
            return;
        }

        if (precioTemp <= 0)
        {
            mensajeError = "El precio debe ser mayor a 0";
            return;
        }

        // Verificar si ya existe el material
        if (orden.Detalles.Any(d => d.MaterialId == materialSeleccionadoId))
        {
            mensajeError = "Este material ya fue agregado a la orden";
            return;
        }

        // Agregar el detalle
        orden.Detalles.Add(new OrdenCompraDetalle
        {
            OrdenCompraId = orden.OrdenCompraId,
            MaterialId = materialSeleccionadoId,
            Cantidad = cantidadTemp,
            Precio = precioTemp
        });

        // Limpiar campos temporales
        materialSeleccionadoId = 0;
        materialSeleccionado = null;
        cantidadTemp = 1;
        precioTemp = 0;
    }

    private void EliminarDetalle(int index)
    {
        if (index >= 0 && index < orden.Detalles.Count)
        {
            orden.Detalles.RemoveAt(index);
        }
    }

    private decimal CalcularTotal()
    {
        return orden.Detalles.Sum(d => d.Cantidad * d.Precio);
    }

    private string ObtenerNombreMaterial(int materialId)
    {
        return ListaMateriales.FirstOrDefault(m => m.MaterialId == materialId)?.Nombre ?? "N/A";
    }

    private async Task Guardar()
    {
        if (orden.ProveedorId <= 0)
        {
            toastService.ShowError("Debe seleccionar un proveedor");
            return;
        }

        if (!orden.Detalles.Any())
        {
            toastService.ShowError("Debe agregar al menos un material");
            return;
        }

        orden.Total = CalcularTotal();

        var resultado = await ordenService.Guardar(orden);

        if (resultado)
        {
            toastService.ShowSuccess("Orden de compra modificada con éxito!");
            navegar.NavigateTo("/OrdenesCompra");
        }
        else
        {
            toastService.ShowError("Error: Stock insuficiente para algún material");
        }
    }

    private async Task Confirmar()
    {
        if (orden != null)
        {
            var resultado = await ordenService.Confirmar(orden);

            if (resultado)
            {
                toastService.ShowSuccess("Orden confirmada!");
                navegar.NavigateTo("/OrdenesCompra");
            }
            else
            {
                toastService.ShowError("Error al confirmar la orden");
            }
        }
    }

    private async Task CancelarOrden()
    {
        if (orden != null)
        {
            var resultado = await ordenService.Cancelar(orden);

            if (resultado)
            {
                toastService.ShowSuccess("Orden cancelada. Stock devuelto!");
                navegar.NavigateTo("/OrdenesCompra");
            }
            else
            {
                toastService.ShowError("Error al cancelar la orden");
            }
        }
    }

    private async Task Recuperar()
    {
        if (orden != null)
        {
            var resultado = await ordenService.Recuperar(orden);

            if (resultado)
            {
                toastService.ShowSuccess("Orden recuperada!");
                navegar.NavigateTo("/OrdenesCompra");
            }
            else
            {
                toastService.ShowError("Error: Stock insuficiente para recuperar la orden");
            }
        }
    }

    private async Task EliminarOrden()
    {
        if (orden != null)
        {
            var resultado = await ordenService.Eliminar(orden);

            if (resultado)
            {
                toastService.ShowSuccess("Orden eliminada!");
                navegar.NavigateTo("/OrdenesCompra");
            }
            else
            {
                toastService.ShowError("Error al eliminar la orden");
            }
        }
    }
}