@page "/OrdenesCompra"
@rendermode InteractiveServer

@using CleanHome.Models
@using CleanHome.Services
@using CleanHome.Extensions

@inject OrdenCompraService ordenService
@inject ToastService toastService

<PageTitle>Registro de Órdenes de Compra</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0">Registro de Órdenes de Compra</h5>
            <a href="/OrdenesCompra/Crear_Orden" class="btn btn-primary">
                <span class="bi bi-plus-square"></span> Crear
            </a>
        </div>

        <div class="card-body">
            <!-- FILTROS -->
            <div class="mb-4">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label"><strong>Filtro</strong></label>
                        <select class="form-control" @bind="Filtro">
                            <option value="" disabled selected>Elija una opción</option>
                            <option value="Proveedor">Proveedor</option>
                            <option value="Estado">Estado</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label"><strong>Búsqueda</strong></label>
                        <div class="input-group">
                            <input class="form-control" @bind="ValorFiltro" placeholder="Buscar..." />
                            <button type="button" class="btn btn-outline-primary" @onclick="Buscar">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <button type="button" class="btn btn-outline-secondary" @onclick="LimpiarFiltros">
                            <i class="bi bi-x-circle"></i> Limpiar
                        </button>
                    </div>
                </div>
            </div>

            <!-- TABLA -->
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Fecha</th>
                            <th>Proveedor</th>
                            <th>Total</th>
                            <th>Estado</th>
                            <th class="text-center">Opciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ListaOrdenes.Any())
                        {
                            @foreach (var orden in ListaOrdenes)
                            {
                                <tr>
                                    <td>@orden.OrdenCompraId</td>
                                    <td>@orden.Fecha.ToShortDateString()</td>
                                    <td>@orden.Proveedor?.Nombre</td>
                                    <td>@orden.Total.ToString("C2")</td>
                                    <td>
                                        <span class="badge @GetBadgeClass(orden.EstadoOrden)">
                                            @orden.EstadoOrden
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <!-- Ver Detalle -->
                                        <a href="/OrdenesCompra/Detalle/@orden.OrdenCompraId"
                                               class="btn btn-outline-info btn-sm" title="Ver detalle">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <!-- Editar -->
                                        <a href="/OrdenesCompra/Editar/@orden.OrdenCompraId"
                                               class="btn btn-outline-primary btn-sm" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <!-- Eliminar (deshabilitado si está Confirmada) -->
                                        @if (orden.EstadoOrden == "Confirmada")
                                        {
                                            <button class="btn btn-outline-secondary btn-sm"
                                                    title="No se puede eliminar una orden confirmada"
                                                    disabled>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-danger btn-sm"
                                                    title="Eliminar"
                                                    @onclick="() => ConfirmarEliminar(orden)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">
                                    No hay órdenes registradas
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer">
            <span class="text-muted">Total de registros: <strong>@ListaOrdenes.Count</strong></span>
        </div>
    </div>
</div>

<!-- MODAL DE CONFIRMACIÓN -->
@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle"></i> Confirmar Eliminación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro que desea eliminar la orden <strong>#@ordenAEliminar?.OrdenCompraId</strong>?</p>
                    <p class="text-muted">Esta acción no se puede deshacer.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal">
                        <i class="bi bi-x-circle"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-danger" @onclick="EliminarOrden">
                        <i class="bi bi-trash"></i> Eliminar
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<OrdenCompra> ListaOrdenes = new();
    private string Filtro = string.Empty;
    private string ValorFiltro = string.Empty;

    // Modal
    private bool mostrarModal = false;
    private OrdenCompra? ordenAEliminar = null;

    protected override async Task OnInitializedAsync()
    {
        await CargarOrdenes();
    }

    private async Task CargarOrdenes()
    {
        ListaOrdenes = await ordenService.Listar(o => true);
    }

    private async Task Buscar()
    {
        if (string.IsNullOrEmpty(Filtro) || string.IsNullOrEmpty(ValorFiltro))
        {
            await CargarOrdenes();
            return;
        }

        ListaOrdenes = Filtro switch
        {
            "Proveedor" => await ordenService.Listar(
                o => o.Proveedor!.Nombre.ToLower().Contains(ValorFiltro.ToLower())),

            "Estado" => await ordenService.Listar(
                o => o.EstadoOrden.ToLower().Contains(ValorFiltro.ToLower())),

            _ => await ordenService.Listar(o => true)
        };
    }

    private async Task LimpiarFiltros()
    {
        Filtro = string.Empty;
        ValorFiltro = string.Empty;
        await CargarOrdenes();
    }

    private void ConfirmarEliminar(OrdenCompra orden)
    {
        ordenAEliminar = orden;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        ordenAEliminar = null;
    }

    private async Task EliminarOrden()
    {
        if (ordenAEliminar != null)
        {
            var resultado = await ordenService.Eliminar(ordenAEliminar);

            if (resultado)
            {
                toastService.ShowSuccess("Orden eliminada con éxito!");
                await CargarOrdenes();
            }
            else
            {
                toastService.ShowError("No se puede eliminar esta orden");
            }

            CerrarModal();
        }
    }

    private string GetBadgeClass(string estado)
    {
        return estado switch
        {
            "Pendiente" => "bg-warning text-dark",
            "Confirmada" => "bg-success",
            "Cancelada" => "bg-danger",
            _ => "bg-secondary"
        };
    }
}