@using CleanHome.Models
@using CleanHome.Services
@inject OrdenCompraService ordenService;

@page "/OrdenesCompra"

<PageTitle>Registro de Ordenes de Compra</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-center ">
            <h5 class="card-title">Registro de Ordenes de Compra</h5>
            <a href="/OrdenesCompra/Crear_Orden" class="btn btn-primary">
                <span class="bi-plus-square"></span> Crear
            </a>
        </div>

        <div class="card-body">

            <div class="mb-4">
                <div class="row">
                    <div class="col-6">
                        <label class="col-form-label"><strong>Filtro</strong></label>
                    </div>
                    <div class="col-6">
                        <label class="col-form-label"><strong>Búsqueda</strong></label>
                    </div>
                </div>

                <div class="row align-items-center">
                    <div class="col-6">
                        <InputSelect class="form-control" @bind-Value="Filtro">
                            <option value="" selected disabled hidden>Elija una opción</option>
                            <option value="Proveedor">Proveedor</option>
                            <option value="Estado">Estado</option>
                        </InputSelect>
                    </div>

                    <div class="col-6">
                        <div class="input-group">
                            <input class="form-control" @bind="ValorFiltro" placeholder="Buscar..." />
                            <button type="button" class="btn btn-outline-primary bi bi-search" @onclick="Buscar"></button>
                        </div>
                    </div>
                </div>
            </div>

            <table class="table table-hover table-responsive">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Proveedor</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th>Opciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var orden in ListaOrdenes)
                    {
                        <tr>
                            <td>@orden.Fecha.ToShortDateString()</td>
                            <td>@orden.Proveedor?.Nombre</td>
                            <td>@orden.Total</td>

                            <td class="text-center">
                                <a href="@($"/OrdenesCompra/Detalle/{orden.OrdenCompraId}")">
                                   class="btn btn-outline-info bi bi-eye"></a>

                                <a href="@($"/OrdenesCompra/Editar/{orden.OrdenCompraId}")"
                                   class="btn btn-outline-primary bi bi-pencil-square"></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="card-footer">
                <label>Cantidad: @ListaOrdenes.Count()</label>
            </div>

        </div>
    </div>
</div>

@code {
    public List<OrdenCompra> ListaOrdenes { get; set; } = new();
    public string Filtro { get; set; } = string.Empty;
    public string ValorFiltro { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ListaOrdenes = await ordenService.Listar(o => o.OrdenCompraId > 0);
    }

    public async Task Buscar()
    {
        if (Filtro != "")
        {
            if (Filtro == "Proveedor")
            {
                ListaOrdenes = await ordenService.Listar(
                    o => o.Proveedor!.Nombre.ToLower().Contains(ValorFiltro.ToLower()));
            }

        }
        else
        {
            ListaOrdenes = await ordenService.Listar(o => o.OrdenCompraId > 0);
        }

        Filtro = string.Empty;
        ValorFiltro = string.Empty;
    }
}