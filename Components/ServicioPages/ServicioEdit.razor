@page "/Servicios/Editar_Servicio/{Id:int}"

<PageTitle>Editar Servicio</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header text-center">
            <h5 class="card-title">Editar Servicio</h5>
        </div>

        <div class="card-body ">
            <div class="row gx-2 g-5 mt-1 mb-1 justify-content-center">

                @* Nombre *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Nombre</strong></label>
                    <input type="text" class="form-control" value="Limpieza Profunda" />
                </div>

                @* Precio *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Precio</strong></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" step="0.01" class="form-control" value="3000.00" />
                    </div>
                </div>

                @* Descripción *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Descripción</strong></label>
                    <input type="text" class="form-control" value="Limpieza a fondo incluyendo ventanas y muebles." />
                </div>

                @* Duración *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Duración (Horas)</strong></label>
                    <input type="number" class="form-control" value="4" />
                </div>

            </div>
        </div>

        @*footer*@
        <div class="card-footer text-center mt-2">
            <a href="/Servicios" class="btn btn-secondary"> <span class="bi bi-arrow-left"></span> Volver</a>
            <button type="button" class="btn btn-primary bi bi-floppy"> Guardar</button>

            @* Aquí irá tu lógica @if(servicio.Estado == Estados.Activo) para alternar botones *@
            <button type="button" class="btn btn-danger bi bi-trash"> Eliminar</button>

            @* Ejemplo del botón recuperar (oculto visualmente en este mockup estático) *@
            @* <button type="button" class="btn btn-success bi bi-arrow-counterclockwise"> Recuperar</button> *@
        </div>
    </div>
</div>