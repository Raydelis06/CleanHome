@page "/Servicios/Crear_Servicio"

<PageTitle>Crear Servicio</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header text-center">
            <h5 class="card-title">Crear Servicio</h5>
        </div>

        <div class="card-body ">
            <div class="row gx-2 g-5 mt-1 mb-1 justify-content-center">

                @* Nombre *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Nombre</strong></label>
                    <input type="text" class="form-control" placeholder="Ej: Limpieza Profunda" />
                </div>

                @* Precio *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Precio</strong></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                </div>

                @* Descripción *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Descripción</strong></label>
                    <input type="text" class="form-control" placeholder="Detalles del servicio..." />
                </div>

                @* Duración *@
                <div class="col-md-5">
                    <label class="form-label"><strong>Duración (Horas)</strong></label>
                    <input type="number" class="form-control" placeholder="Ej: 2" />
                </div>

            </div>
        </div>

        @*footer*@
        <div class="card-footer text-center mt-2">
            <a href="/Servicios" class="btn btn-secondary"> <span class="bi bi-arrow-left"></span> Volver</a>
            <button type="button" class="btn btn-primary bi bi-floppy"> Guardar</button>
        </div>
    </div>
</div>