@page "/Facturacion/Crear"
@using CleanHome.Models
@using CleanHome.Extensions
@using CleanHome.Services
@inject MaterialService materialService
@inject NavigationManager navegar
@inject ToastService toastService
@inject FacturaService facturaService
@rendermode InteractiveServer

<PageTitle>Crear factura</PageTitle>

<EditForm Model="facturas" OnValidSubmit="Guardar">
	<DataAnnotationsValidator />
	<div class="container">
		<div class="card shadow-lg">
			<div class="card-header text-center">
				<h5 class="card-title">Crear tipo de servicio</h5>
			</div>

			<div class="card-body">
				<div class="row gx-2 g-5 mt-1 mb-1 justify-content-center">

					@* Nombre *@
					<div class="col-md-5">
						<label class="form-label"><strong>Nombre</strong></label>
						<InputText class="form-control" @bind-Value="facturas.Nombre" />
						<ValidationMessage For="@(() => facturas.Nombre)" />
					</div>


					@* Precio Servicio *@
					<div class="col-md-5">
						<label class="form-label"><strong>Precio Servicio</strong></label>
						<div class="input-group">
							<span class="input-group-text">$</span>
							<InputNumber class="form-control" @bind-Value="PrecioServicio" />

						</div>
					</div>

					@* Precio Materiales *@
					@* <div class="col-md-5">
						<label class="form-label"><strong>Precio Materiales</strong></label>
						<div class="input-group">
							<span class="input-group-text">$</span>
							<InputNumber TValue="double" class="form-control" Value="PrecioMateriales" ValueExpression="() => PrecioMateriales" readonly/>

						</div>
					</div> *@

					@* Total *@
					@* <div class="col-md-5">
						<label class="form-label"><strong>Total Servicio</strong></label>
						<div class="input-group">
							<span class="input-group-text">$</span>
							<InputNumber TValue="double" class="form-control" Value="Total" ValueExpression="() => Total" readonly/>
						</div>
					</div> *@
					
					

					@* Materiales *@
					@* <div class="col-md-5">
						<label class="form-label"><strong>Materiales</strong></label>
						<InputSelect class="form-control" @bind-Value="material.MaterialId" @bind-Value:after="CambiodeMaterial">
							<option value="0" selected disabled hidden>Seleccione un producto...</option>
							@if (ListaProductos != null)
							{
								@foreach (var item in ListaProductos)
								{
									<option value="@item.MaterialId">@item.Nombre</option>
								}
							}
						</InputSelect>
						<ValidationMessage For="@(() => material.MaterialId)"/>
					</div> *@

				</div>
			</div>

			@* footer *@
			<div class="card-footer text-center mt-2">
				<a href="/Servicios" class="btn btn-secondary">
					<span class="bi bi-arrow-left"></span> Volver
				</a>

				<button type="submit" class="btn btn-primary bi bi-floppy">
					Guardar
				</button>
			</div>
		</div>
	</div>
</EditForm>

@code
{
	private Materiales material = new();
	private Facturas facturas = new();
	private List<Materiales?> ListaProductos { get; set; } = new();

	private double PrecioServicio { get; set; }
	private double PrecioMateriales { get; set; }
	private double Total => PrecioServicio + PrecioMateriales;

	protected override async Task OnInitializedAsync()
	{
		// ListaProductos = await materialService.Listar(p => p.MaterialId > 0);
	}

	// private void CambiodeMaterial()
	// {

	// 	var mat = ListaProductos.FirstOrDefault(x => x.MaterialId == material.MaterialId);

	// 	if (mat != null)
	// 	{
	// 		PrecioMateriales = mat.Precio;
	// 	}
	// 	else
	// 	{
	// 		PrecioMateriales = 0;
	// 	}
	// }

	private async Task Guardar()
	{
		var factura = new Facturas()
		{
			Nombre = facturas.Nombre,
			Fecha = facturas.Fecha,
			// MaterialId = material.MaterialId,
			MontoTotal = Total
		};

		var guardar = await facturaService.Guardar(facturas);

		if (guardar)
		{
			toastService.ShowSuccess("La factura ha sido creado con exito");
			navegar.NavigateTo("/Facturacion");
		}
		else
		{
			toastService.ShowError("Error: no se pudo guardar la factura");
		}
	}
}