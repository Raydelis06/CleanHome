@page "/Facturacion/Crear"
@rendermode InteractiveServer

@using CleanHome.Extensions
@using CleanHome.Models
@using CleanHome.Services

@inject FacturaService facturaService
@inject MaterialService materialService
@inject ServicioService servicioService
@inject NavigationManager navegar
@inject ToastService toastService

<PageTitle>Crear Factura</PageTitle>

<div class="container">
    <div class="card shadow-lg">

        <div class="card-header text-center">
            <h5 class="card-title mb-0">Crear Factura</h5>
        </div>

        <div class="card-body">

            <EditForm Model="factura" OnValidSubmit="Guardar">
                <DataAnnotationsValidator />

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Código Factura</strong></label>
                        <InputText class="form-control" @bind-Value="factura.CodigoFactura" readonly />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><strong>Nombre</strong></label>
                        <InputText class="form-control" @bind-Value="factura.Nombre" />
                        <ValidationMessage For="@(() => factura.Nombre)" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label"><strong>Fecha</strong></label>
                        <InputDate class="form-control" @bind-Value="factura.Fecha" />
                        <ValidationMessage For="@(() => factura.Fecha)" />
                    </div>
                </div>

                <hr />

                <h6 class="mb-3"><i class="bi bi-plus-circle"></i> Agregar Material</h6>

                <div class="row g-3 mb-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Material</label>
                        <select class="form-control" value="@materialSeleccionadoId"
                                @onchange="OnMaterialSeleccionado">
                            <option value="0" disabled selected>Seleccione</option>
                            @foreach (var material in ListaMateriales)
                            {
                                <option value="@material.MaterialId">
                                    @material.Nombre - Stock: @material.CantidadDisponible
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Cantidad</label>
                        <input type="number" class="form-control" @bind="cantidadMaterialTemp" min="1" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Precio Unitario</label>
                        <input type="number" class="form-control" readonly @bind="precioMaterialTemp" min="0.01" step="0.01" />
                        @if (materialSeleccionado != null)
                        {
                            <small class="text-muted">
                                Precio sugerido: @materialSeleccionado.Precio.ToString("C2")
                            </small>
                        }
                    </div>

                    <div class="col-md-3">
                        <button type="button" class="btn btn-success w-100" @onclick="AgregarMaterial">
                            <i class="bi bi-plus"></i> Agregar
                        </button>
                    </div>
                </div>

                <h6 class="mb-3"><i class="bi bi-plus-circle"></i> Agregar Servicio</h6>

                <div class="row g-3 mb-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">Servicio</label>
                        <select class="form-control" value="@servicioSeleccionadoId"
                                @onchange="OnServicioSeleccionado">
                            <option value="0" disabled selected>Seleccione</option>
                            @foreach (var servicio in ListaServicios)
                            {
                                <option value="@servicio.ServicioId">
                                    @servicio.Nombre
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-md-2">
                        <label class="form-label">Cantidad</label>
                        <input type="number" class="form-control" @bind="cantidadServicioTemp" min="1" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Precio Unitario</label>
                        <input type="number" class="form-control" readonly @bind="precioServicioTemp" min="0.01" step="0.01" />
                        @if (servicioSeleccionado != null)
                        {
                            <small class="text-muted">
                                Precio sugerido: @servicioSeleccionado.Precio.ToString("C2")
                            </small>
                        }
                    </div>

                    <div class="col-md-3">
                        <button type="button" class="btn btn-success w-100" @onclick="AgregarServicio">
                            <i class="bi bi-plus"></i> Agregar
                        </button>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @mensajeError
                        <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
                    </div>
                }

                <h6 class="mb-3"><i class="bi bi-list-ul"></i> Detalles de la Factura</h6>

                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Tipo</th>
                                <th>Nombre</th>
                                <th>Cantidad</th>
                                <th>Precio Unit.</th>
                                <th>Importe</th>
                                <th class="text-center">Acción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (factura.Detalles.Any() || factura.Servicios.Any())
                            {
                                @foreach (var (detalle, index) in factura.Detalles.Select((d, i) => (d, i)))
                                {
                                    <tr>
                                        <td>@(index + 1)</td>
                                        <td><span class="badge bg-info">Material</span></td>
                                        <td>@ObtenerNombreMaterial(detalle.MaterialId)</td>
                                        <td>@detalle.Cantidad</td>
                                        <td>@detalle.Precio.ToString("C2")</td>
                                        <td>@((detalle.Cantidad * detalle.Precio).ToString("C2"))</td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-danger btn-sm"
                                                    @onclick="() => EliminarDetalle(index)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }

                                @foreach (var (servicio, index) in factura.Servicios.Select((s, i) => (s, i)))
                                {
                                    <tr>
                                        <td>@(factura.Detalles.Count + index + 1)</td>
                                        <td><span class="badge bg-warning">Servicio</span></td>
                                        <td>@ObtenerNombreServicio(servicio.ServicioId)</td>
                                        <td>@servicio.Cantidad</td>
                                        <td>@servicio.Precio.ToString("C2")</td>
                                        <td>@((servicio.Cantidad * servicio.Precio).ToString("C2"))</td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-danger btn-sm"
                                                    @onclick="() => EliminarServicio(index)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">
                                        No hay materiales ni servicios agregados
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-primary">
                                <td colspan="5" class="text-end"><strong>TOTAL:</strong></td>
                                <td colspan="2"><strong>@CalcularTotal().ToString("C2")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex justify-content-center gap-2 mt-4">
                    <a href="/Facturacion" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-primary" disabled="@(!(factura.Detalles.Any() || factura.Servicios.Any()))">
                        <i class="bi bi-floppy"></i> Guardar Factura
                    </button>
                </div>
            </EditForm>

        </div>
    </div>
</div>

@code {
    private Facturas factura = new();
    private List<Materiales> ListaMateriales = new();
    private List<Servicios> ListaServicios = new();
    private string mensajeError = string.Empty;

    private int materialSeleccionadoId = 0;
    private Materiales? materialSeleccionado = null;
    private int cantidadMaterialTemp = 1;
    private decimal precioMaterialTemp = 0;

    private int servicioSeleccionadoId = 0;
    private Servicios? servicioSeleccionado = null;
    private int cantidadServicioTemp = 1;
    private decimal precioServicioTemp = 0;

    protected override async Task OnInitializedAsync()
    {
        ListaMateriales = await materialService.Listar(m => m.Estado == Estados.Activo);
        ListaServicios = await servicioService.Listar(s => s.Estado == Estados.Activo);
        factura.Fecha = DateTime.Now;
        factura.CodigoFactura = $"FAC-{DateTime.Now:yyyyMMddHHmmss}";
    }

    private void OnMaterialSeleccionado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            materialSeleccionadoId = id;
            materialSeleccionado = ListaMateriales.FirstOrDefault(m => m.MaterialId == id);

            if (materialSeleccionado != null)
            {
                precioMaterialTemp = (decimal)materialSeleccionado.Precio;
            }
        }
    }

    private void OnServicioSeleccionado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            servicioSeleccionadoId = id;
            servicioSeleccionado = ListaServicios.FirstOrDefault(s => s.ServicioId == id);

            if (servicioSeleccionado != null)
            {
                precioServicioTemp = (decimal)servicioSeleccionado.Precio;
            }
        }
    }

    private void AgregarMaterial()
    {
        mensajeError = string.Empty;

        if (materialSeleccionadoId <= 0)
        {
            mensajeError = "Debe seleccionar un material";
            return;
        }

        if (cantidadMaterialTemp <= 0)
        {
            mensajeError = "La cantidad debe ser mayor a 0";
            return;
        }

        if (precioMaterialTemp <= 0)
        {
            mensajeError = "El precio debe ser mayor a 0";
            return;
        }

        var material = ListaMateriales.FirstOrDefault(m => m.MaterialId == materialSeleccionadoId);
        if (material == null || material.CantidadDisponible < cantidadMaterialTemp)
        {
            mensajeError = "No hay suficiente cantidad disponible de este material";
            return;
        }

        if (factura.Detalles.Any(d => d.MaterialId == materialSeleccionadoId))
        {
            mensajeError = "Este material ya fue agregado a la factura";
            return;
        }

        factura.Detalles.Add(new FacturaDetalle
        {
            MaterialId = materialSeleccionadoId,
            Cantidad = cantidadMaterialTemp,
            Precio = precioMaterialTemp
        });

        materialSeleccionadoId = 0;
        materialSeleccionado = null;
        cantidadMaterialTemp = 1;
        precioMaterialTemp = 0;
    }

    private void AgregarServicio()
    {
        mensajeError = string.Empty;

        if (servicioSeleccionadoId <= 0)
        {
            mensajeError = "Debe seleccionar un servicio";
            return;
        }

        if (cantidadServicioTemp <= 0)
        {
            mensajeError = "La cantidad debe ser mayor a 0";
            return;
        }

        if (precioServicioTemp <= 0)
        {
            mensajeError = "El precio debe ser mayor a 0";
            return;
        }

        if (factura.Servicios.Any(s => s.ServicioId == servicioSeleccionadoId))
        {
            mensajeError = "Este servicio ya fue agregado a la factura";
            return;
        }

        factura.Servicios.Add(new FacturaServicio
        {
            ServicioId = servicioSeleccionadoId,
            Cantidad = cantidadServicioTemp,
            Precio = precioServicioTemp
        });

        servicioSeleccionadoId = 0;
        servicioSeleccionado = null;
        cantidadServicioTemp = 1;
        precioServicioTemp = 0;
    }

    private void EliminarDetalle(int index)
    {
        if (index >= 0 && index < factura.Detalles.Count)
        {
            factura.Detalles.RemoveAt(index);
        }
    }

    private void EliminarServicio(int index)
    {
        if (index >= 0 && index < factura.Servicios.Count)
        {
            factura.Servicios.RemoveAt(index);
        }
    }

    private string ObtenerNombreMaterial(int materialId)
    {
        return ListaMateriales.FirstOrDefault(m => m.MaterialId == materialId)?.Nombre ?? "Desconocido";
    }

    private string ObtenerNombreServicio(int servicioId)
    {
        return ListaServicios.FirstOrDefault(s => s.ServicioId == servicioId)?.Nombre ?? "Desconocido";
    }

    private decimal CalcularTotal()
    {
        var totalMateriales = factura.Detalles.Sum(d => d.Cantidad * d.Precio);
        var totalServicios = factura.Servicios.Sum(s => s.Cantidad * s.Precio);
        return totalMateriales + totalServicios;
    }

    private async Task Guardar()
    {
        if (!factura.Detalles.Any() && !factura.Servicios.Any())
        {
            toastService.ShowError("Debe agregar al menos un material o servicio");
            return;
        }

        factura.MontoTotal = CalcularTotal();
        var resultado = await facturaService.Guardar(factura);

        if (resultado)
        {
            toastService.ShowSuccess("La factura ha sido creada con éxito");
            navegar.NavigateTo("/Facturacion");
        }
        else
        {
            toastService.ShowError("Error: no se pudo guardar la factura (posible stock insuficiente)");
        }
    }
}
