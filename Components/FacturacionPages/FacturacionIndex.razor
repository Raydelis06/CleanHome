@page "/Facturacion"
@using CleanHome.Models
@using CleanHome.Extensions
@using CleanHome.Services
@inject FacturaService facturaService
@inject NavigationManager navegar
@inject ToastService toastService
@rendermode InteractiveServer

<PageTitle>Registro de Facturas</PageTitle>

<div class="container">
	<div class="card shadow-lg">
		<div class="card-header d-flex justify-content-between align-items-center">
			<h5 class="card-title mb-0">Registro de Facturas</h5>
			<a href="/Facturacion/Crear" class="btn btn-primary">
				<span class="bi bi-plus-square"></span> Crear
			</a>
		</div>

		<div class="card-body">
			<div class="mb-4">
				<div class="row">
					<div class="col-6">
						<label class="col-form-label"><strong>Filtro</strong></label>
					</div>
					<div class="col-6">
						<label class="col-form-label"><strong>Búsqueda</strong></label>
					</div>
				</div>

				<div class="row align-items-center">
					<div class="col-6">
						<InputSelect class="form-control" @bind-Value="Filtro">
							<option value="" selected disabled hidden>Elija una opción</option>
							<option value="">Todos</option>
							<option value="Codigo">Código de Factura</option>
							<option value="Cliente">Cliente</option>
							<option value="Fecha">Fecha</option>
							<option value="Pagada">Pagadas</option>
							<option value="Pendiente">Pendientes</option>
							<option value="Cancelada">Canceladas</option>
							<option value="FacturasEliminadas">Facturas Inactivas</option>
						</InputSelect>
					</div>

					<div class="col-6">
						<div class="input-group">
							@if (Filtro == "Fecha")
							{
								<InputDate @bind-Value="FechaFiltro" class="form-control" />
							}
							else
							{
								<input class="form-control" @bind="ValorFiltro" placeholder="Buscar..." />
							}
							<button type="button" class="btn btn-outline-primary bi bi-search" @onclick="Buscar"></button>
						</div>
					</div>
				</div>
			</div>

			<div class="table-responsive">
				<table class="table table-hover">
					<thead class="table-primary">
						<tr>
							<th>Código</th>
							<th>Cliente</th>
							<th>Fecha</th>
							<th>Monto Total</th>
							<th>Estado Factura</th>
							<th class="text-center">Opciones</th>
						</tr>
					</thead>
					<tbody>
						@if (ListaFacturas.Count == 0)
						{
							<tr>
								<td colspan="6" class="text-center text-muted py-4">
									No hay facturas que mostrar
								</td>
							</tr>
						}
						else
						{
							@foreach (var factura in ListaFacturas)
								{
									<tr class="@(factura.Estado == Estados.Inactivo ? "text-muted" : "")">
										<td>@factura.CodigoFactura</td>
										<td>@factura.Nombre</td>
										<td>@factura.Fecha.ToShortDateString()</td>
										<td>@factura.MontoTotal.ToString("C2")</td>
										<td>
											@if (factura.EstadoFactura == EstadosFactura.Pendiente)
											{
												<span class="badge bg-warning text-dark">Pendiente</span>
											}
											else if (factura.EstadoFactura == EstadosFactura.Pagada)
											{
												<span class="badge bg-success">Pagada</span>
											}
											else if (factura.EstadoFactura == EstadosFactura.Cancelada)
											{
												<span class="badge bg-danger">Cancelada</span>
											}
										</td>
										<td class="text-center">
											<a href="@($"/Facturacion/Detalle/{factura.FacturaId}")" 
											   class="btn btn-outline-info btn-sm bi bi-eye" 
											   title="Ver Detalle"></a>
											<a href="@($"/Facturacion/Editar/{factura.FacturaId}")" 
											   class="btn btn-outline-primary btn-sm bi bi-pencil-square" 
											   title="Editar"></a>
										</td>
									</tr>
								}
						}
					</tbody>
				</table>
			</div>

			<div class="card-footer text-muted">
				<small>Total de registros: @ListaFacturas.Count()</small>
			</div>
		</div>
	</div>
</div>

@code {
	private DateTime? FechaFiltro { get; set; }
	private List<Facturas> ListaFacturas { get; set; } = new();

	private string Filtro { get; set; } = "";
	private string ValorFiltro { get; set; } = "";

	protected override async Task OnInitializedAsync()
	{
		await CargarFacturas();
	}

	private async Task CargarFacturas()
	{
        ListaFacturas = await facturaService.Listar(a =>
            a.FacturaId > 0 && a.Estado == Estados.Activo);
	}

	private async Task Buscar()
	{
		if (string.IsNullOrWhiteSpace(Filtro) || Filtro == "")
		{
			await CargarFacturas();
			return;
		}

		switch (Filtro)
		{
			case "Codigo":
				ListaFacturas = await facturaService.Listar(a =>
					a.Estado == Estados.Activo &&
					(a.CodigoFactura ?? "").ToLower().Contains(ValorFiltro.ToLower()));
				break;

			case "Cliente":
				ListaFacturas = await facturaService.Listar(a =>
					a.Estado == Estados.Activo &&
					(a.Nombre ?? "").ToLower().Contains(ValorFiltro.ToLower()));
				break;

            case "Fecha":
                if (FechaFiltro != null)
                {
                    ListaFacturas = await facturaService.Listar(a =>
                        a.Estado == Estados.Activo &&
                        a.Fecha.Date == FechaFiltro.Value.Date);
                }
                break;

			case "Pagada":
				ListaFacturas = await facturaService.Listar(a =>
					a.EstadoFactura == EstadosFactura.Pagada && a.Estado == Estados.Activo);
				break;

			case "Pendiente":
				ListaFacturas = await facturaService.Listar(a =>
					a.EstadoFactura == EstadosFactura.Pendiente && a.Estado == Estados.Activo);
				break;

			case "Cancelada":
				ListaFacturas = await facturaService.Listar(a =>
					a.EstadoFactura == EstadosFactura.Cancelada & a.Estado != Estados.Inactivo);
				break;

			case "FacturasEliminadas":
				ListaFacturas = await facturaService.Listar(a =>
					a.Estado == Estados.Inactivo);
				break;
		}
	}
}