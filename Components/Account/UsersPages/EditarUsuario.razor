@page "/Usuarios/Editar/{Id}"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using CleanHome.Models
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")] 

<PageTitle>Editar Usuario</PageTitle>

<div class="container">
    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title">Editar Usuario</h5>
            <a href="/Usuarios" class="btn btn-outline-secondary bi bi-arrow-left"> Volver</a>
        </div>
        <div class="card-body">

            @if (!string.IsNullOrEmpty(Mensaje))
            {
                <div class="alert @(EsError ? "alert-danger" : "alert-success") alert-dismissible fade show">
                    @Mensaje
                    <button type="button" class="btn-close" @onclick="() => Mensaje = string.Empty"></button>
                </div>
            }

            @if (Usuario != null)
            {
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Email</strong></label>
                        <input class="form-control" value="@Usuario.Email" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Usuario</strong></label>
                        <input class="form-control" value="@Usuario.UserName" disabled />
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Email Confirmado</strong></label>
                        <input class="form-control" value="@(Usuario.EmailConfirmed ? "Sí" : "No")" disabled />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label"><strong>Rol Actual</strong></label>
                        <input class="form-control" value="@RolActual" disabled />
                    </div>
                </div>

                <hr />
                <h6 class="mb-3">Cambiar Rol</h6>
                <div class="row align-items-end">
                    <div class="col-md-6">
                        <label class="form-label"><strong>Nuevo Rol</strong></label>
                        <InputSelect class="form-control" @bind-Value="NuevoRol">
                            <option value="" disabled hidden>Seleccione un rol</option>
                            @foreach (var rol in RolesDisponibles)
                            {
                                <option value="@rol">@rol</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <button class="btn btn-warning" @onclick="AbrirModal"
                                disabled="@(string.IsNullOrEmpty(NuevoRol) || NuevoRol == RolActual)">
                            <span class="bi bi-shield-lock me-1"></span> Cambiar Rol
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@* Modal de confirmación de contraseña *@
@if (MostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title bi bi-shield-lock"> Confirmar Identidad</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <p>Para cambiar el rol de <strong>@Usuario?.Email</strong> a <strong>@NuevoRol</strong>, confirma tu contraseña de administrador.</p>

                    @if (!string.IsNullOrEmpty(ErrorModal))
                    {
                        <div class="alert alert-danger">@ErrorModal</div>
                    }

                    <div class="mb-3">
                        <label class="form-label"><strong>Tu contraseña</strong></label>
                        <input type="password" class="form-control" @bind="PasswordAdmin"
                               placeholder="Ingresa tu contraseña..." />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button class="btn btn-danger" @onclick="ConfirmarCambioRol" disabled="@Procesando">
                        @if (Procesando)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        Confirmar Cambio
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private ApplicationUser? Usuario { get; set; }
    private string RolActual { get; set; } = "Sin rol";
    private string NuevoRol { get; set; } = string.Empty;
    private List<string> RolesDisponibles { get; set; } = new();

    private bool MostrarModal { get; set; } = false;
    private string PasswordAdmin { get; set; } = string.Empty;
    private string ErrorModal { get; set; } = string.Empty;
    private bool Procesando { get; set; } = false;

    private string Mensaje { get; set; } = string.Empty;
    private bool EsError { get; set; } = false;

    protected override async Task OnInitializedAsync()
    {
        Usuario = await UserManager.FindByIdAsync(Id);

        if (Usuario == null)
        {
            Navigation.NavigateTo("/Usuarios");
            return;
        }

        var roles = await UserManager.GetRolesAsync(Usuario);
        RolActual = roles.FirstOrDefault() ?? "Sin rol";
        NuevoRol = RolActual != "Sin rol" ? RolActual : string.Empty;

        RolesDisponibles = RoleManager.Roles.Select(r => r.Name!).ToList();
    }

    private void AbrirModal()
    {
        ErrorModal = string.Empty;
        PasswordAdmin = string.Empty;
        MostrarModal = true;
    }

    private void CerrarModal()
    {
        MostrarModal = false;
        PasswordAdmin = string.Empty;
        ErrorModal = string.Empty;
    }

    private async Task ConfirmarCambioRol()
    {
        if (string.IsNullOrWhiteSpace(PasswordAdmin))
        {
            ErrorModal = "Debes ingresar tu contraseña.";
            return;
        }

        Procesando = true;

        try
        {
            // Obtener el admin actual
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var adminEmail = authState.User.Identity?.Name;
            var adminUser = await UserManager.FindByNameAsync(adminEmail!);

            if (adminUser == null)
            {
                ErrorModal = "No se pudo verificar tu identidad.";
                return;
            }

            // Validar contraseña del admin
            var passwordValida = await UserManager.CheckPasswordAsync(adminUser, PasswordAdmin);

            if (!passwordValida)
            {
                ErrorModal = "Contraseña incorrecta. Inténtalo de nuevo.";
                return;
            }

            // Quitar roles anteriores
            var rolesActuales = await UserManager.GetRolesAsync(Usuario!);
            if (rolesActuales.Any())
                await UserManager.RemoveFromRolesAsync(Usuario!, rolesActuales);

            // Asignar nuevo rol
            var resultado = await UserManager.AddToRoleAsync(Usuario!, NuevoRol);

            if (resultado.Succeeded)
            {
                RolActual = NuevoRol;
                Mensaje = $"Rol cambiado a '{NuevoRol}' exitosamente.";
                EsError = false;
                CerrarModal();
            }
            else
            {
                ErrorModal = "Error al asignar el rol: " + string.Join(", ", resultado.Errors.Select(e => e.Description));
            }
        }
        finally
        {
            Procesando = false;
        }
    }
}
