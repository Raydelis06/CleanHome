@using CleanHome.Extensions
@using CleanHome.Models
@using CleanHome.Services
@inject ProveedorService proveedorService
@inject NavigationManager navegar
@inject ToastService toastService
@page "/Proveedores/Editar_Proveedor/{Id:int}"
@rendermode InteractiveServer

<PageTitle>Editar Proveedor</PageTitle>

	<div class="container">
		<div class="card shadow-lg">
			<div class="card-header text-center">
				<h5 class="card-title">Editar Proveedor</h5>
			</div>
			<EditForm Model="proveedor" OnValidSubmit="Guardar">
			<DataAnnotationsValidator />
				<div class="card-body ">
				
					<div class="row gx-2 g-5 mt-1 mb-1 justify-content-center">
						@* Nombre *@
						<div class="col-md-5">
							<label class="form-label"><strong>Nombre: </strong></label>
							<div>
								<label>@proveedor.Nombre</label>
							</div>
						</div>
						@* Dirección *@
						<div class="col-md-5">
							<label class="form-label"><strong>Dirección</strong></label>
							<InputText class="form-control" @bind-Value="proveedor.Direccion"></InputText>
							<ValidationMessage For="@(() => proveedor.Direccion)" />
						</div>
						@* Teléfono *@
						<div class="col-md-5">
							<label class="form-label"><strong>Teléfono</strong></label>
							<InputText class="form-control" @bind-Value="proveedor.Telefono"></InputText>
							<ValidationMessage For="@(() => proveedor.Telefono)" />
						</div>
					</div>
				</div>
				@*footer*@
				<div class="card-footer text-center mt-3 d-flex justify-content-center">
					<div class="d-flex justify-content-between gap-2">
						<a href="/Proveedores" class="btn btn-secondary"> <span class="bi bi-arrow-left"></span> Volver</a>
						<button type="submit" class="btn btn-primary bi bi-floppy"> Guardar</button>
						@if (proveedor.Estado == Estados.Activo)
						{
							<button class="btn btn-danger bi bi-trash" @onclick="Eliminar"> Eliminar</button>
						}
						else
						{
							<button class="btn btn-success bi bi-arrow-counterclockwise" @onclick="Recuperar"> Recuperar</button>
						}
					</div>
				</div>
			</EditForm>
		</div>
	</div>

@code
{
	[Parameter]
	public int Id { get; set; }

	Proveedores? proveedor = new();

	protected override async Task OnInitializedAsync()
	{
		proveedor = await proveedorService.Buscar(Id);
	}

	async Task Guardar()
	{
		if(proveedor != null)
		{
			var modificado = await proveedorService.Guardar(proveedor);
			if (modificado)
			{
				toastService.ShowSuccess("El proveedor ha sido modificado con exito!");
				navegar.NavigateTo("/Proveedores");
			}
			else
				toastService.ShowWarning("Error al modificar el proveedor.");
		}

	}
	async Task Eliminar()
	{
		if(proveedor != null)
		{
			var eliminado = await proveedorService.Eliminar(proveedor);
			if (eliminado)
			{
				toastService.ShowSuccess("El proveedor se ha eliminado con exito!");
				navegar.NavigateTo("/Proveedores");

			}
			else
				toastService.ShowError("Ha ocurrido un error al eliminar el proveedor");
		}

	}
	async Task Recuperar()
	{
		if(proveedor != null)
		{
			var recuperado = await proveedorService.Recuperar(proveedor);
			if (recuperado)
			{
				toastService.ShowSuccess("El proveedor ha sido recuperado con exito!");
				navegar.NavigateTo("/Proveedores");
			}
			else
				toastService.ShowError("Ha ocurrido un error al recuperar el proveedor");
			
		}
		
	}
}
